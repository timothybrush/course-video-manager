{
  "name": "course-video-manager",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm run generate-assets && react-router build",
    "generate-assets": "tsx scripts/generate-assets.ts",
    "dev": "pnpm run \"/dev:/\"",
    "dev:stream-deck-forwarder": "tsx watch stream-deck-forwarder/run-stream-deck-forwarder.ts",
    "dev:react-router": "react-router dev",
    "test": "vitest",
    "start": "pnpm run generate-assets && pnpm run build:if-needed && pnpm run \"/start:/\"",
    "build:if-needed": "tsx scripts/build-if-needed.ts",
    "start:react-router": "PORT=5173 node --env-file=.env node_modules/@react-router/serve/bin.js ./build/server/index.js",
    "start:stream-deck-forwarder": "tsx stream-deck-forwarder/run-stream-deck-forwarder.ts",
    "typecheck": "react-router typegen && tsgo",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:clone-local": "./scripts/clone-db-to-local.sh",
    "sandcastle": "npx tsx ./.sandcastle/main.ts",
    "check:file-tokens": "./scripts/check-file-tokens.sh"
  },
