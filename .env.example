# Database Configuration
DATABASE_URL="postgresql://postgres:password@localhost:5432/ai-app-template"

# API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# File Paths
FINISHED_VIDEOS_DIRECTORY="/path/to/finished-videos"
DUMP_FILE_LOCATION="/path/to/database-backups/cvm.sql"

# Dropbox API (publish transport)
# Create a scoped app at https://www.dropbox.com/developers/apps with
# full-Dropbox access. The remote path is the Courses folder within the account.
DROPBOX_APP_KEY="your_dropbox_app_key_here"
DROPBOX_APP_SECRET="your_dropbox_app_secret_here"
DROPBOX_REMOTE_PATH="/Courses"

# pg_dump container name (default: ai-app-template-postgres)
# PG_DUMP_CONTAINER="ai-app-template-postgres"

# CVM server base URL for CLI backup coordination
CVM_SERVER_URL="http://localhost:5173"

# Video Files
# Directory where per-video scratch files are stored, keyed by lineageId.
# Files are organized as: {VIDEO_FILES_DIR}/{lineageId}/{filename}
VIDEO_FILES_DIR="/path/to/video-files"

# Diagram Thumbnails
# Directory where PNG thumbnails of preserved diagram snapshots are stored.
# Files are organized as: {DIAGRAM_THUMBNAILS_DIR}/{diagramId}/{contentHash}.png
DIAGRAM_THUMBNAILS_DIR="/path/to/diagram-thumbnails"

# Google OAuth (for YouTube uploads)
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"

# AWS S3 (vertical video upload for Buffer social posts)
# A public-read bucket in eu-west-2 with a 1-day lifecycle expiry rule on the
# `cvm/buffer-posts/` prefix. Buffer fetches the uploaded object via its plain
# public URL (no auth / presigning).
AWS_ACCESS_KEY_ID="your_aws_access_key_id_here"
AWS_SECRET_ACCESS_KEY="your_aws_secret_access_key_here"
AWS_REGION="eu-west-2"
S3_BUCKET="your_s3_bucket_name_here"

# Background Removal (remove.bg)
# Get an API key at https://www.remove.bg/api (50 free images/month)
REMOVE_BG_API_KEY="your_remove_bg_api_key_here"

# Space Desk (virtual TikTok-shaped monitor)
# The "Space Desk" sidebar button opens a modal to enter the server IP (saved in
# local storage). Only the port is configurable via env (defaults to 28252):
# SPACEDESK_PORT="28252"
